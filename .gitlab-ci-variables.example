# GitLab CI/CD Variables Configuration Example
# Copy this file and configure the variables in your GitLab project settings
# Go to: Settings > CI/CD > Variables
# 
# This configuration is for the to-be-continuous Helm template v9.2.3+
# Documentation: https://to-be-continuous.gitlab.io/doc/ref/helm/

# =============================================================================
# GLOBAL CONFIGURATION
# =============================================================================

# Base application name (defaults to $CI_PROJECT_NAME)
# HELM_BASE_APP_NAME=fossology

# Helm CLI image version
# HELM_CLI_IMAGE=docker.io/alpine/helm:latest

# Chart and scripts directories
# HELM_CHART_DIR=.
# HELM_SCRIPTS_DIR=.

# Common values file for all environments
# HELM_COMMON_VALUES=values.yaml

# =============================================================================
# PUBLISHING CONFIGURATION
# =============================================================================

# Publishing method (auto, push, post, put, custom, disabled)
# HELM_PUBLISH_METHOD=auto

# Publishing strategy (manual, auto, none)
# HELM_PUBLISH_STRATEGY=manual

# Publishing triggers (prod, protected, all, tag)
# HELM_PUBLISH_ON=prod

# Option 1: GitLab Container Registry (OCI) - Default
# HELM_PUBLISH_URL=oci://$CI_REGISTRY/$CI_PROJECT_PATH/charts
# HELM_PUBLISH_USER=$CI_REGISTRY_USER
# HELM_PUBLISH_PASSWORD=$CI_REGISTRY_PASSWORD

# Option 2: GitLab Package Registry (Helm)
# HELM_PUBLISH_URL=${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/packages/helm/release
# HELM_PUBLISH_USER=gitlab-ci-token
# HELM_PUBLISH_PASSWORD=$CI_JOB_TOKEN

# Option 3: External OCI Registry (Harbor, AWS ECR, etc.)
# HELM_PUBLISH_URL=oci://harbor.example.com/charts
# HELM_PUBLISH_USER=robot$helm-pusher
# HELM_PUBLISH_PASSWORD=your-robot-token

# Option 4: External Chart Repository
# HELM_PUBLISH_URL=https://charts.example.com/api/charts
# HELM_PUBLISH_USER=your-username
# HELM_PUBLISH_PASSWORD=your-password

# =============================================================================
# ENVIRONMENT CONFIGURATION
# =============================================================================

# Default environment URL pattern (supports late variable expansion)
# HELM_ENVIRONMENT_URL=https://%{environment_name}.example.com

# Review environments (dynamic environments for feature branches)
# HELM_REVIEW_ENABLED=true
# HELM_REVIEW_APP_NAME=${HELM_BASE_APP_NAME}-${CI_ENVIRONMENT_SLUG}
# HELM_REVIEW_ENVIRONMENT_URL=https://%{environment_name}.review.example.com
# HELM_REVIEW_NAMESPACE=review
# HELM_REVIEW_VALUES=values-review.yaml
# HELM_REVIEW_AUTOSTOP_DURATION=4 hours
# HELM_REVIEW_KUBE_CONFIG=<base64-encoded-kubeconfig>

# Integration environment (for develop branch)
# HELM_INTEG_ENABLED=true
# HELM_INTEG_APP_NAME=${HELM_BASE_APP_NAME}-integration
# HELM_INTEG_ENVIRONMENT_URL=https://%{environment_name}.example.com
# HELM_INTEG_NAMESPACE=integration
# HELM_INTEG_VALUES=values-integration.yaml
# HELM_INTEG_KUBE_CONFIG=<base64-encoded-kubeconfig>

# Staging environment (for main/master branch)
# HELM_STAGING_ENABLED=true
# HELM_STAGING_APP_NAME=${HELM_BASE_APP_NAME}-staging
# HELM_STAGING_ENVIRONMENT_URL=https://%{environment_name}.example.com
# HELM_STAGING_NAMESPACE=staging
# HELM_STAGING_VALUES=values-staging.yaml
# HELM_STAGING_KUBE_CONFIG=<base64-encoded-kubeconfig>

# Production environment (for main/master branch)
# HELM_PROD_ENABLED=true
# HELM_PROD_APP_NAME=${HELM_BASE_APP_NAME}
# HELM_PROD_ENVIRONMENT_URL=https://fossology.example.com
# HELM_PROD_NAMESPACE=production
# HELM_PROD_VALUES=values-production.yaml
# HELM_PROD_DEPLOY_STRATEGY=manual
# HELM_PROD_KUBE_CONFIG=<base64-encoded-kubeconfig>

# =============================================================================
# KUBERNETES CONFIGURATION
# =============================================================================

# Default Kubernetes namespace
# KUBE_NAMESPACE=default

# Kubernetes context (for GitLab agents)
# KUBE_CONTEXT=path/to/agent/project:agent-name

# Default kubeconfig (base64 encoded)
# Generate with: kubectl config view --raw --minify | base64 -w 0
# HELM_DEFAULT_KUBE_CONFIG=<base64-encoded-kubeconfig>

# =============================================================================
# CHART REPOSITORIES
# =============================================================================

# Helm chart repositories (space-separated list of name@url)
# HELM_REPOS=stable@https://charts.helm.sh/stable bitnami@https://charts.bitnami.com/bitnami

# Repository authentication (for private repositories)
# HELM_REPO_<NAME>_USER=username
# HELM_REPO_<NAME>_PASSWORD=password

# =============================================================================
# JOB CONFIGURATION
# =============================================================================

# Helm lint configuration
# HELM_LINT_DISABLED=false
# HELM_LINT_ARGS=lint --strict

# YAML lint configuration
# HELM_YAMLLINT_DISABLED=false
# HELM_YAMLLINT_CONFIG={extends: relaxed, rules: {line-length: {max: 160}}}

# Kube-score configuration
# HELM_KUBE_SCORE_DISABLED=false
# HELM_K8S_VERSION=v1.28

# Helm test configuration
# HELM_TEST_ENABLED=false
# HELM_TEST_ARGS=test

# Package configuration
# HELM_PACKAGE_ARGS=package --dependency-update
# HELM_PUBLISH_SNAPSHOT_ENABLED=false
# HELM_SEMREL_RELEASE_DISABLED=false

# =============================================================================
# VARIABLE SETTINGS IN GITLAB
# =============================================================================

# When setting these variables in GitLab:
# 1. Go to your project > Settings > CI/CD > Variables
# 2. Add each variable with appropriate settings:
#    - Type: Variable (default)
#    - Environment scope: All (default) or specific environments
#    - Protect variable: ✓ (for sensitive data)
#    - Mask variable: ✓ (for passwords/tokens)
#    - Expand variable reference: ✓ (if using $CI_* variables)

# Example variable configurations:

# HELM_PUBLISH_URL: 
#   - Value: oci://$CI_REGISTRY/$CI_PROJECT_PATH/charts
#   - Protected: ✓
#   - Masked: ✗
#   - Expand: ✓

# HELM_PUBLISH_PASSWORD:
#   - Value: $CI_REGISTRY_PASSWORD
#   - Protected: ✓
#   - Masked: ✓
#   - Expand: ✓

# HELM_DEFAULT_KUBE_CONFIG:
#   - Value: LS0tLS1CRUdJTi1DRVJUSUZJQ0FURS0tLS0t...
#   - Protected: ✓
#   - Masked: ✓
#   - Expand: ✗

# HELM_STAGING_KUBE_CONFIG:
#   - Value: LS0tLS1CRUdJTi1DRVJUSUZJQ0FURS0tLS0t...
#   - Protected: ✓
#   - Masked: ✓
#   - Expand: ✗
#   - Environment scope: staging (optional)

# HELM_PROD_KUBE_CONFIG:
#   - Value: LS0tLS1CRUdJTi1DRVJUSUZJQ0FURS0tLS0t...
#   - Protected: ✓
#   - Masked: ✓
#   - Expand: ✗
#   - Environment scope: production (optional)

# =============================================================================
# MIGRATION FROM LEGACY VARIABLES
# =============================================================================

# If migrating from a previous implementation, map these variables:
# Old Variable                    -> New Variable
# HELM_REGISTRY_URL              -> HELM_PUBLISH_URL (with oci:// prefix for OCI)
# HELM_REGISTRY_USER             -> HELM_PUBLISH_USER
# HELM_REGISTRY_PASSWORD         -> HELM_PUBLISH_PASSWORD
# KUBE_CONFIG_STAGING            -> HELM_STAGING_KUBE_CONFIG
# KUBE_CONFIG_PRODUCTION         -> HELM_PROD_KUBE_CONFIG
# CHART_VERSION                  -> Use semantic-release or Chart.yaml version
# HELM_REPO_URL                  -> HELM_PUBLISH_URL (for traditional repos)